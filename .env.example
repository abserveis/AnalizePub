# AnalizePub — Environment Variables
# Copy this file to `.env` for local development.
# In production (Fly.io) these values are configured via `fly secrets`.

# HTTP server bind config
HOST=0.0.0.0
PORT=8080

# Optional: override the directory used to store ephemeral session data.
# Defaults to /tmp/analizepub_sessions if unset.
# ANALIZEPUB_SESSIONS_DIR=/tmp/analizepub_sessions

# Optional: maximum upload size in bytes (default 50 MB).
# ANALIZEPUB_MAX_UPLOAD_BYTES=52428800

# Optional: session TTL in seconds (default 7200 = 2h).
# ANALIZEPUB_SESSION_TTL=7200
